# Twilio SMS Broadcaster (Free Trial Tier compatible)
# Get these at https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_number_here

# SOS Emergency Contacts (Comma-separated)
# IMPORTANT: On a free Twilio trial, all these numbers MUST be verified 
# in the Twilio Console (Phone Numbers -> Manage -> Verified Caller IDs)
SOS_CONTACTS=+919876543210,+15556667777
